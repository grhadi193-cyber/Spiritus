# Application
APP_NAME=Spiritus
APP_VERSION=2.0.0
DEBUG=false

# Server
HOST=0.0.0.0
VPN_WEB_PORT=38471
VPN_API_PORT=10085

# Xray
VPN_SERVER_IP=your-server-ip
VPN_SERVER_PORT=443
VPN_SNI_HOST=www.google.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://spiritus:spiritus@db:5432/spiritus

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-with-secure-random-value
JWT_SECRET_KEY=change-me-in-production-with-secure-random-value
JWT_ALGORITHM=HS256

# TOTP
TOTP_ISSUER=Spiritus

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Features
ENABLE_2FA=true
ENABLE_WEBAUTHN=false
ENABLE_TELEGRAM_BOT=false
TELEGRAM_BOT_TOKEN=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Audit
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true
