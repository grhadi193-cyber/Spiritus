[Unit]
Description=V7LTHRONYX VPN Management Panel
Documentation=https://github.com/v74all/Spiritus
After=network.target xray.service
Wants=xray.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/spiritus
Environment="PYTHONUNBUFFERED=1"
Environment="PATH=/opt/spiritus/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/opt/spiritus/venv/bin/python3 /opt/spiritus/vpn-web.py
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=10
StartLimitInterval=60
StartLimitBurst=3

PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/spiritus /usr/local/etc/xray /var/log/xray /tmp
LimitNOFILE=65536

StandardOutput=append:/opt/spiritus/vpn-panel.log
StandardError=append:/opt/spiritus/vpn-panel.log
SyslogIdentifier=v7lthronyx

[Install]
WantedBy=multi-user.target